#!/usr/bin/env bash
# Thin wrapper so you can run the tool as `./backport <cmd>` from anywhere.
#
# It bridges AWS_REGION -> AWS_DEFAULT_REGION (boto3 reads the latter, so the AI
# layer picks up whichever you set) and then dispatches to main.py. Every argument
# is forwarded verbatim: `./backport analyze --commit <sha>`.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ -n "${AWS_REGION:-}" ] && [ -z "${AWS_DEFAULT_REGION:-}" ]; then
  export AWS_DEFAULT_REGION="$AWS_REGION"
fi

exec python3 "$here/src/main.py" "$@"
